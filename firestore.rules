rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Rules for the active reports collection
    match /reports/{reportId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Rules for the soft-deleted trash items collection
    match /trash/{trashId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Rules for custom user suggestions dictionaries
    // Document ID matches the user's Auth UID (request.auth.uid)
    match /dictionaries/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
